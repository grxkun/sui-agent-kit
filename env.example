# ─────────────────────────────────────────────────────────────────────────────
# sui-agent-kit — example environment variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── Deployed contract ─────────────────────────────────────────────────────────
PACKAGE_ID=0x...
AGENT_REGISTRY_ID=0x...
TASK_BOARD_ID=0x...

# ── Wallets (hex-encoded 32-byte private keys) ────────────────────────────────
# Generate with: sui keytool generate ed25519
SUI_PRIVATE_KEY=

# Example 1 — register-agent
# (uses SUI_PRIVATE_KEY above)

# Example 2 — post-and-fulfill-task
POSTER_PRIVATE_KEY=
POSTER_AGENT_CARD_ID=0x...
POSTER_REPUTATION_ID=0x...
WORKER_PRIVATE_KEY=
WORKER_AGENT_CARD_ID=0x...
WORKER_REPUTATION_ID=0x...

# Example 3 — x402-server
PORT=3000
# (uses SUI_PRIVATE_KEY above)

# Example 4 — multi-agent-pipeline
ORCHESTRATOR_KEY=
ORCHESTRATOR_AGENT_ID=0x...
DATA_AGENT_KEY=
DATA_AGENT_ID=0x...
DATA_AGENT_ADDRESS=0x...
RESEARCH_AGENT_KEY=
RESEARCH_AGENT_ID=0x...
RESEARCH_AGENT_ADDRESS=0x...
TRADE_AGENT_KEY=
TRADE_AGENT_ID=0x...
TRADE_AGENT_ADDRESS=0x...

# Example 5 — payment-stream
PAYER_KEY=
AGENT_KEY=
